---
import { getEntry, getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const inicio = await getEntry('paginas', 'inicio');
if (!inicio) {
  throw new Error("No se pudo cargar 'src/content/paginas/inicio.yaml'. Verifica que el archivo exista y que la colección esté registrada en config.ts.");
}
const d = inicio.data;
const hero = d.zona_hero;
const porqueRh = d.seccion_porque_rh!;
const cta = d.seccion_cta!;
const contacto = d.seccion_contacto_formulario!;

const allServicios = await getCollection('servicios');
const servicios = allServicios.sort((a, b) => a.data.meta.orden - b.data.meta.orden);

const slugToHref: Record<string, string> = {
  'derecho-marcario': '/derecho-marcario',
  'derecho-migratorio': '/derecho-migratorio',
  'otros-servicios': '/otros-servicios',
};

const pilarIcons: Record<string, string> = {
  balanza: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><path d="M5 21h14"/><path d="M12 3l-5 9h10L12 3z" fill="none"/><circle cx="12" cy="3" r="0.5" fill="#A61A32"/><line x1="3" y1="9" x2="12" y2="3"/><line x1="21" y1="9" x2="12" y2="3"/><path d="M3 9l-1.5 4.5h3L3 9z"/><path d="M21 9l-1.5 4.5h3L21 9z"/></svg>`,
  globo: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3c-2 2.5-3 5.5-3 9s1 6.5 3 9"/><path d="M12 3c2 2.5 3 5.5 3 9s-1 6.5-3 9"/><path d="M3.6 9h16.8"/><path d="M3.6 15h16.8"/></svg>`,
  escudo: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l7 3v6c0 4.5-3 8.5-7 10C9 19.5 5 15.5 5 11V5l7-3z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  cronometro: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="8"/><polyline points="12 9 12 13 14.5 15.5"/><line x1="10" y1="3" x2="14" y2="3"/><line x1="12" y1="3" x2="12" y2="5"/><line x1="19.5" y1="6.5" x2="21" y2="5"/></svg>`,
  manos: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12l4-4 3 1 3-2 3 2 3-1 4 4"/><path d="M2 12c1 2 3 4 5 4l2-2 2 2 2-2 2 2c2 0 4-2 5-4"/><line x1="9" y1="9" x2="9" y2="16"/><line x1="15" y1="9" x2="15" y2="16"/></svg>`,
  candado: `<svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/><circle cx="12" cy="16" r="1" fill="#A61A32" stroke="none"/></svg>`,
};
---

<Layout
  title="RH Legal Services | Abogados en Colombia — Visas, Marcas y Derecho Corporativo"
  description="Firma legal especializada en derecho migratorio, registro de marcas y derecho corporativo en Colombia. Asesoría experta para extranjeros e inversionistas. Consulta gratis."
  lang="es"
  canonicalEs="/"
  canonicalEn="/en/"
  lcpImage="/images/bogota-skyline.jpg"
>
  <Navbar lang="es" currentPath="/" />

  <!-- ── HERO ── -->
  <section class="relative min-h-screen flex items-center" id="inicio" style="min-height:100svh;">
    <img src={hero.imagen_fondo} alt="R&H Legal Services" fetchpriority="high" loading="eager" width="1920" height="1080" class="absolute inset-0 w-full h-full object-cover -z-10" />
    <div class="absolute inset-0 bg-navy-950/50"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/70 via-navy-950/30 to-transparent"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 w-full">
      <div class="grid lg:grid-cols-5 gap-10 items-center">
        <!-- Left: Copy (3 cols) -->
        <div class="lg:col-span-3">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.1] mb-6">
            {hero.titulo_es.split(',')[0]},<br />
            <span class="text-brand-400">{hero.titulo_es.split(',')[1]?.trim()}</span>
          </h1>

          <p class="text-lg text-white/85 leading-relaxed mb-3 max-w-lg">
            {hero.subtitulo_es}
          </p>

          <p class="text-sm font-semibold text-white mb-8 max-w-lg">
            {hero.aclaracion_es}
          </p>

          <div class="flex flex-wrap gap-4 mb-10">
            <a
              href="#por-que-rh"
              class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-bold px-7 py-4 rounded-xl transition-all duration-200 shadow-xl hover:shadow-brand-500/40 hover:-translate-y-0.5"
            >
              Más Información
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            </a>
            <a
              href="https://wa.me/573002170870"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 border border-white/30 text-white font-semibold px-7 py-4 rounded-xl transition-all duration-200 backdrop-blur-sm"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
              </svg>
              WhatsApp
            </a>
          </div>

          <!-- Trust badges -->
          <div class="flex flex-wrap gap-6">
            {[
              { n: '+200', l: 'Visas gestionadas' },
              { n: '+500', l: 'Marcas registradas' },
              { n: '10+', l: 'Años de experiencia' },
            ].map(b => (
              <div class="text-center">
                <div class="text-2xl font-bold text-brand-300">{b.n}</div>
                <div class="text-xs text-white/65">{b.l}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Form (2 cols — narrower) -->
        <div id="contacto" class="lg:col-span-2 min-h-[500px] lg:min-h-[520px]">
          <div class="relative">
            <div class="absolute -inset-1 bg-brand-500/20 rounded-2xl blur-sm"></div>
            <div class="relative">
              <div class="bg-navy-900/85 backdrop-blur-sm rounded-t-2xl px-6 py-4 border-b border-white/10">
                <h2 class="text-white font-bold text-base">{contacto.titulo_es}</h2>
                <p class="text-white/55 text-xs mt-0.5">{contacto.descripcion_es}</p>
              </div>
              <ContactForm lang="es" formId="hero-form" compact={true} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROPUESTA DE VALOR ── -->
  <section class="py-20 bg-white" id="por-que-rh">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-xs font-bold uppercase tracking-widest" style="color:#A61A32;">¿Por qué RH Legal?</span>
        <h2 class="text-3xl sm:text-4xl font-bold mt-3 mb-4" style="color:#A61A32;">{porqueRh.titulo_es}</h2>
        <p class="text-slate-500 max-w-xl mx-auto leading-relaxed">{porqueRh.descripcion_es}</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {porqueRh.pilares.map(pilar => (
          <div class="group p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
            <Fragment set:html={pilarIcons[pilar.icono] ?? pilarIcons['escudo']} />
            <h3 class="font-bold text-navy-900 text-lg mb-2">{pilar.titulo_es}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{pilar.texto_es}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SERVICIOS ── -->
  <section class="py-20 bg-navy-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-brand-300 text-xs font-bold uppercase tracking-widest">Nuestros Servicios</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-white mt-3 mb-4">Soluciones legales completas en Colombia</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicios.map(s => (
          <a href={slugToHref[s.data.meta.slug] ?? `/${s.data.meta.slug}`} class="group block relative overflow-hidden rounded-2xl">
            <img src={s.data.tarjeta_inicio.imagen_fondo_tarjeta} alt={s.data.tarjeta_inicio.alt_es ?? s.data.tarjeta_inicio.titulo_es} class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="400" />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-900/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-white font-bold text-xl mb-1">{s.data.tarjeta_inicio.titulo_es}</h3>
              <p class="text-white/70 text-sm mb-3 leading-relaxed">{s.data.tarjeta_inicio.mini_descripcion_es}</p>
              <span class="inline-flex items-center gap-1 text-brand-300 text-sm font-bold">
                Ver servicio
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ── -->
  <section class="py-20 bg-gradient-to-br from-brand-600 to-accent-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{cta.titulo_es}</h2>
      <p class="text-white/80 text-lg mb-8">{cta.subtitulo_es}</p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-brand-600 font-bold px-8 py-4 rounded-xl text-lg transition-all duration-200 shadow-2xl hover:-translate-y-0.5"
      >
        {cta.texto_boton_es}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>

  <Footer lang="es" />
  <WhatsAppWidget lang="es" page="home" />
</Layout>
