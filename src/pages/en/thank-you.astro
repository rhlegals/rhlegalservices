---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Thank You for Contacting Us! — RH Legal Services"
  description="We received your inquiry. An RH Legal attorney will contact you within 24 business hours."
  lang="en"
  canonicalEs="/gracias"
  canonicalEn="/en/thank-you"
>
  <!-- noindex to keep success pages out of crawl -->
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <Navbar lang="en" currentPath="/en/thank-you" variant="thankyou" />

  <main class="min-h-screen bg-white flex items-center justify-center pt-16">
    <div class="max-w-xl mx-auto px-4 sm:px-6 text-center py-20">
      <!-- Success icon -->
      <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-8 animate-pulse" style="background-color:rgba(166,26,50,0.1);border:2px solid #A61A32;">
        <svg class="w-10 h-10" style="color:#A61A32;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <span class="text-xs font-bold uppercase tracking-widest mb-4 block" style="color:#A61A32;">Request Received</span>
      <h1 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-5">Thank you for contacting us!</h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-4">
        We have successfully received your inquiry.
      </p>
      <p class="text-gray-500 leading-relaxed mb-10">
        One of our attorneys will review your case and get in touch within <strong class="text-navy-900">24 business hours</strong>.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a
          href="https://wa.me/573002170870?text=Hello%2C%20I%20just%20submitted%20a%20form%20on%20your%20website%20and%20would%20like%20to%20speak%20with%20an%20attorney."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#20bb5a] text-white font-bold px-6 py-3.5 rounded-xl transition-all duration-200 shadow-lg hover:-translate-y-0.5"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          Chat on WhatsApp
        </a>
        <a
          href="/en/"
          class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 border border-gray-200 text-navy-900 font-semibold px-6 py-3.5 rounded-xl transition-all duration-200"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Home
        </a>
      </div>

      <div class="grid grid-cols-3 gap-6 text-center border-t border-gray-200 pt-10">
        {[
          { n: '200+', l: 'Visas handled' },
          { n: '500+', l: 'Trademarks registered' },
          { n: '10+', l: 'Years of experience' },
        ].map(b => (
          <div>
            <div class="text-2xl font-bold" style="color:#A61A32;">{b.n}</div>
            <div class="text-xs text-gray-500 mt-1">{b.l}</div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer lang="en" />
</Layout>
