---
import { getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import WhatsAppWidget from '../../components/WhatsAppWidget.astro';

const servicio = await getEntry('servicios', 'derecho-marcario');
if (!servicio) {
  throw new Error("Could not load 'src/content/servicios/derecho-marcario.yaml'. Verify the file exists and the collection is registered in config.ts.");
}
const pi = servicio.data.pagina_interna;

const faqItems = (pi.seccion_faq ?? []).map(f => ({
  question: f.pregunta_en,
  answer: f.respuesta_en,
}));
---

<Layout
  title="Trademark Registration in Colombia | Intellectual Property Law — RH Legal Services"
  description="Register your trademark in Colombia with the SIC. Expert attorneys for prior art search, Nice classification, filing, defense, and renewal. Free consultation."
  lang="en"
  canonicalEs="/derecho-marcario"
  canonicalEn="/en/trademark-law"
  ogImage="https://rhlegalservices.com/images/trademark-ip.jpg"
  lcpImage="/images/trademark-ip.jpg"
>
  <Navbar lang="en" currentPath="/en/trademark-law" />

  <!-- ── HERO ── -->
  <section class="relative min-h-[70vh] flex items-center">
    <img src={pi.hero_imagen_fondo} alt="R&H Legal Services" fetchpriority="high" loading="eager" class="absolute inset-0 w-full h-full object-cover -z-10" />
    <div class="absolute inset-0 bg-navy-950/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16 w-full">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-brand-500/20 border border-brand-400/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-brand-300 text-xs font-semibold tracking-wider uppercase">Trademark Law</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-5">
          {pi.hero_titulo_en.split(' and ')[0]} and<br />
          <span class="text-brand-300">{pi.hero_titulo_en.split(' and ').slice(1).join(' and ')}</span>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          {pi.introduccion_en}
        </p>
        <a href="#contact" class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-bold px-7 py-4 rounded-xl transition-all duration-200 shadow-xl hover:-translate-y-0.5">
          Register your trademark now
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICES ── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-brand-500 text-xs font-bold uppercase tracking-widest">Services</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mt-3 mb-4">Everything you need to protect your brand</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Prior Art Search -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9.5" cy="9.5" r="5.5"/>
            <line x1="13.5" y1="13.5" x2="19" y2="19"/>
            <line x1="7" y1="9.5" x2="12" y2="9.5"/>
            <line x1="9.5" y1="7" x2="9.5" y2="12"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[0]?.titulo_en ?? 'Prior Art Search'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[0]?.texto_en ?? ''}</p>
        </div>
        <!-- Nice Classification -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[1]?.titulo_en ?? 'Nice Classification'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[1]?.texto_en ?? ''}</p>
        </div>
        <!-- Filing SIC -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <polyline points="9 15 12 12 15 15"/>
            <line x1="12" y1="12" x2="12" y2="18"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[2]?.titulo_en ?? 'Filing with the SIC'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[2]?.texto_en ?? ''}</p>
        </div>
        <!-- Opposition Defense -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 14l6 6"/>
            <rect x="3" y="3" width="8" height="5" rx="1" transform="rotate(45 7 5.5)"/>
            <line x1="4" y1="20" x2="20" y2="20"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[3]?.titulo_en ?? 'Opposition Defense'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[3]?.texto_en ?? ''}</p>
        </div>
        <!-- Trademark Renewal -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 3h14"/>
            <path d="M5 21h14"/>
            <path d="M5 3c0 7 7 9 7 9s7-2 7-9"/>
            <path d="M5 21c0-7 7-9 7-9s7 2 7 9"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[4]?.titulo_en ?? 'Trademark Renewal'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[4]?.texto_en ?? ''}</p>
        </div>
        <!-- Foreign Trademarks -->
        <div class="p-7 rounded-2xl border border-gray-100 hover:border-brand-300 hover:shadow-xl hover:shadow-brand-500/10 transition-all duration-300">
          <svg class="w-9 h-9 mb-4" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="9" r="5"/>
            <path d="M12 4c-1 1.5-1.5 3-1.5 5s0.5 3.5 1.5 5"/>
            <path d="M12 4c1 1.5 1.5 3 1.5 5S12.5 12.5 12 14"/>
            <path d="M7.2 7h9.6"/>
            <path d="M7.2 11h9.6"/>
            <path d="M12 14l-2 7"/>
            <path d="M12 14l2 7"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
          </svg>
          <h3 class="font-semibold text-navy-900 text-lg mb-2">{(pi.bloques_contenido ?? [])[5]?.titulo_en ?? 'Foreign Trademarks in Colombia'}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{(pi.bloques_contenido ?? [])[5]?.texto_en ?? ''}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── TESTIMONIALS ── -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-navy-900">Brands that trust RH Legal</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { text: 'We registered our brand in three classes in record time. The team knows every detail of the SIC process.', author: 'Valentina R.', role: 'Founder, fashion startup' },
          { text: 'I tried to register my trademark myself and got rejected. With RH Legal we succeeded on the first attempt.', author: 'Diego F.', role: 'Food entrepreneur' },
          { text: 'Excellent service for foreign companies. They handled everything remotely with constant updates.', author: 'Sarah K.', role: 'CEO, tech company (USA)' },
        ].map(t => (
          <div class="bg-white p-7 rounded-2xl border border-gray-100 shadow-sm">
            <div class="flex gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mb-5 italic">"{t.text}"</p>
            <div>
              <p class="font-semibold text-navy-900 text-sm">{t.author}</p>
              <p class="text-gray-400 text-xs">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <FaqAccordion
    title="Frequently asked questions about trademark registration in Colombia"
    items={faqItems}
  />

  <!-- ── FORM ── -->
  <section class="py-20 bg-gradient-to-br from-navy-900 to-navy-950" id="contact">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-5">Ready to register your trademark?</h2>
          <p class="text-white/70 leading-relaxed mb-8">Fill in the form and we'll contact you with a detailed, no-obligation quote.</p>
          <div class="space-y-4">
            {[
              'Free prior art search',
              'Clear quote per Nice class',
              '100% remote and digital management',
              'Constant process updates',
            ].map(b => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-white/80 text-sm">{b}</span>
              </div>
            ))}
          </div>
        </div>
        <ContactForm lang="en" formId="tm-en-form" />
      </div>
    </div>
  </section>

  <Footer lang="en" />
  <WhatsAppWidget lang="en" page="trademark" />
</Layout>
