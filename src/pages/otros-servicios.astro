---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const servicio = await getEntry('servicios', 'otros-servicios');
if (!servicio) {
  throw new Error("No se pudo cargar 'src/content/servicios/otros-servicios.yaml'. Verifica que el archivo exista y que la colección esté registrada en config.ts.");
}
const pi = servicio.data.pagina_interna;
const bloques = pi.bloques_contenido ?? [];

const svgIcons: string[] = [
  // 0: Contratos Comerciales — Pluma
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4 12.5-12.5z"/><line x1="15" y1="5" x2="18" y2="8"/></svg>`,
  // 1: Constitución de Sociedades — Engranajes
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="15" r="3.5"/><circle cx="16" cy="9" r="3.5"/><path d="M8 11.5V5M8 21v-2.5M3.5 15H2M13.5 15H12M5 12l-1-1M11 18l-1-1M11 12l1-1M5 18l1-1"/><path d="M16 5.5V3M16 15.5V13M11.5 9H10M21.5 9H20M13 6l-1-1M19 12l-1-1M19 6l1-1M13 12l1-1"/></svg>`,
  // 2: Divorcios — Balanza
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><path d="M5 21h14"/><circle cx="12" cy="3" r="0.5" fill="#A61A32" stroke="none"/><line x1="3" y1="9" x2="12" y2="3"/><line x1="21" y1="9" x2="12" y2="3"/><path d="M3 9l-1.5 4.5h3L3 9z"/><path d="M21 9l-1.5 4.5h3L21 9z"/></svg>`,
  // 3: Sucesiones — Documento con sello
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="12" y2="17"/><circle cx="15" cy="17" r="1.5"/></svg>`,
  // 4: Due Diligence — Lupa
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="10.5" cy="10.5" r="6.5"/><line x1="15.5" y1="15.5" x2="21" y2="21"/></svg>`,
  // 5: Representación — Maletín
  `<svg class="w-8 h-8 mb-3" viewBox="0 0 24 24" fill="none" stroke="#A61A32" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>`,
];
---

<Layout
  title="Derecho Corporativo y Servicios Legales en Colombia — RH Legal Services"
  description="Asesoría en derecho corporativo, contratos comerciales, constitución de sociedades, asuntos civiles y de familia en Colombia. Soluciones para empresas y extranjeros."
  lang="es"
  canonicalEs="/otros-servicios"
  canonicalEn="/en/other-services"
  ogImage="https://rhlegalservices.com/images/corporate-team.jpg"
  lcpImage="/images/corporate-team.jpg"
>
  <Navbar lang="es" currentPath="/otros-servicios" />

  <!-- ── HERO ── -->
  <section class="relative min-h-[55vh] flex items-end pb-16">
    <img src={pi.hero_imagen_fondo} alt="R&H Legal Services" fetchpriority="high" loading="eager" class="absolute inset-0 w-full h-full object-cover -z-10" />
    <div class="absolute inset-0 bg-navy-950/80"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-transparent to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 w-full">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-brand-500/20 border border-brand-400/30 rounded-full px-4 py-1.5 mb-6">
          <span class="text-brand-300 text-xs font-semibold tracking-wider uppercase">Derecho Corporativo y Civil</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-5">
          {pi.hero_titulo_es.split(' para ')[0]} para<br />
          <span class="text-brand-300">{pi.hero_titulo_es.split(' para ').slice(1).join(' para ')}</span>
        </h1>
        <p class="text-white/80 text-lg leading-relaxed mb-8">
          {pi.introduccion_es}
        </p>
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-bold px-7 py-4 rounded-xl transition-all duration-200 shadow-xl hover:-translate-y-0.5"
        >
          Consultar mi caso
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICIOS ── -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span class="text-brand-500 text-xs font-bold uppercase tracking-widest">Nuestros Servicios</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mt-3 mb-4">Soluciones jurídicas integrales para empresas y personas</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {bloques.map((bloque, i) => (
          <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 hover:border-brand-300 hover:bg-white hover:shadow-lg transition-all duration-300">
            <Fragment set:html={svgIcons[i] ?? svgIcons[0]} />
            <h3 class="font-semibold text-navy-900 mb-2">{bloque.titulo_es}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{bloque.texto_es}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FORMULARIO ── -->
  <section class="py-20 bg-gradient-to-br from-navy-900 to-navy-950" id="contacto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-5">¿Necesitas asesoría legal en Colombia?</h2>
          <p class="text-white/70 leading-relaxed mb-8">Cuéntanos tu situación y un abogado especializado te contactará para orientarte con claridad.</p>
          <div class="space-y-4 mb-8">
            {[
              'Asesoría en derecho corporativo y contratos',
              'Constitución de sociedades y trámites Cámara de Comercio',
              'Asuntos civiles, familiares y sucesorales',
              'Respuesta en menos de 24 horas hábiles',
            ].map(b => (
              <div class="flex items-center gap-3">
                <div class="w-5 h-5 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-white/80 text-sm">{b}</span>
              </div>
            ))}
          </div>
          <div class="p-5 bg-white/5 rounded-2xl border border-white/10">
            <p class="text-white font-semibold text-sm mb-1.5">Revisión inicial de tu caso</p>
            <p class="text-white/80 text-sm leading-relaxed">
              Revisamos tu situación y te explicamos las opciones con total claridad. Sin letra pequeña ni compromisos implícitos.
            </p>
          </div>
        </div>
        <ContactForm lang="es" formId="otros-form" />
      </div>
    </div>
  </section>

  <Footer lang="es" />
  <WhatsAppWidget lang="es" page="other" />
</Layout>
