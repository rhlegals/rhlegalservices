---
import { getEntry } from 'astro:content';

export interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;
const isEs = lang === 'es';

const globalEntry = await getEntry('configuracion', 'global');
const globalConfig = globalEntry?.data;
const contact = globalConfig?.contact || {
  email: "contacto@rhlegalservices.com",
  phoneOffice: "+57 (601) 123-4567",
  address: "Bogotá, Colombia",
  addressEn: "Bogota, Colombia",
};
const footerBg = globalConfig?.theme?.footerBg || "bg-navy-900";

const t = {
  tagline: isEs
    ? 'Seguridad jurídica para vivir, trabajar e invertir en Colombia.'
    : 'Legal certainty to live, work, and invest in Colombia.',
  services: isEs ? 'Servicios' : 'Services',
  company: isEs ? 'Empresa' : 'Company',
  legal: isEs ? 'Legal' : 'Legal',
  reviews: isEs ? 'Lo que dicen nuestros clientes' : 'What our clients say',
  follow: isEs ? 'Síguenos en redes:' : 'Follow us:',
  links: isEs
    ? [
        { href: '/derecho-marcario', label: 'Derecho Marcario' },
        { href: '/derecho-migratorio', label: 'Derecho Migratorio' },
        { href: '/otros-servicios', label: 'Derecho Corporativo y Civil' },
        { href: '/blog', label: 'Blog Jurídico' },
      ]
    : [
        { href: '/en/trademark-law', label: 'Trademark Law' },
        { href: '/en/immigration-law', label: 'Immigration Law' },
        { href: '/en/other-services', label: 'Corporate & Civil Law' },
        { href: '/en/blog', label: 'Legal Blog' },
      ],
  company_links: isEs
    ? [
        { href: '/nuestra-firma', label: 'Nuestra Firma' },
        { href: '/', label: 'Inicio' },
        { href: '#contacto', label: 'Contacto' },
      ]
    : [
        { href: '/en/our-firm', label: 'Our Firm' },
        { href: '/en/', label: 'Home' },
        { href: '#contact', label: 'Contact' },
      ],
  legal_links: isEs
    ? [{ href: '/politica-privacidad', label: 'Política de Privacidad' }]
    : [{ href: '/en/privacy-policy', label: 'Privacy Policy' }],
  rights: isEs ? 'Todos los derechos reservados.' : 'All rights reserved.',
  disclaimer: isEs
    ? 'La información de este sitio es de carácter informativo y no constituye asesoría legal. Consulte con nuestros abogados para su caso específico.'
    : 'The information on this site is for informational purposes only and does not constitute legal advice. Please consult with our attorneys for your specific case.',
};
---

<footer class={`${footerBg} text-white`}>
  <!-- Google Reviews Widget Block -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <p class="text-brand-300 text-xs font-bold uppercase tracking-widest mb-6 text-center">{t.reviews}</p>
      <!-- Widget container: replace src with your Elfsight / Tagembed / SociableKIT embed code -->
      <div id="google-reviews-widget" class="w-full min-h-[80px] flex items-center justify-center">
      <div class="elfsight-app-c685cd41-3314-402a-84c0-327ff1ab37f9" data-elfsight-app-lazy></div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="mb-4">
          <img
            src="/RH_Legal_Services.webp"
            alt="RH Legal Services"
            class="h-10 w-auto object-contain"
            loading="lazy"
            width="160"
            height="40"
          />
        </div>
        <p class="text-white/60 text-sm leading-relaxed mb-6">{t.tagline}</p>

        <!-- Social icons -->
        <p class="text-white/70 text-xs font-bold uppercase tracking-widest mb-3">{t.follow}</p>
        <div class="flex items-center gap-3">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/RHLegalServices"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-white/10 hover:bg-[#1877F2] flex items-center justify-center transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.885v2.27h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/rh_legalservices"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-white/10 hover:bg-gradient-to-br hover:from-[#f09433] hover:via-[#e6683c] hover:to-[#dc2743] flex items-center justify-center transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/company/rh-legal-services"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-white/10 hover:bg-[#0A66C2] flex items-center justify-center transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- WhatsApp -->
          <a
            href="https://wa.me/573002170870"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-lg bg-white/10 hover:bg-[#25D366] flex items-center justify-center transition-colors"
            aria-label="WhatsApp"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-brand-300 font-bold text-sm uppercase tracking-widest mb-5">{t.services}</h3>
        <ul class="space-y-3">
          {t.links.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-brand-300 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-brand-300 font-bold text-sm uppercase tracking-widest mb-5">{t.company}</h3>
        <ul class="space-y-3">
          {t.company_links.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-brand-300 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal + Contact -->
      <div>
        <h3 class="text-brand-300 font-bold text-sm uppercase tracking-widest mb-5">{t.legal}</h3>
        <ul class="space-y-3 mb-6">
          {t.legal_links.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-brand-300 text-sm transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
        <div class="text-white/50 text-xs space-y-1.5">
          <p>{isEs ? contact.address : contact.addressEn}</p>
          {contact.phoneOffice && <p>{contact.phoneOffice}</p>}
          <a href={`mailto:${contact.email}`} class="hover:text-brand-300 transition-colors block">{contact.email}</a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8">
      <p class="text-white/30 text-xs leading-relaxed mb-3">{t.disclaimer}</p>
      <p class="text-white/40 text-xs">&copy; {new Date().getFullYear()} RH Legal Services. {t.rights}</p>
    </div>
  </div>
</footer>
<script>
  // Creamos un observador para cargar el widget solo cuando el footer esté cerca
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // El footer ya es visible o está cerca, inyectamos el script real
        const script = document.createElement('script');
        script.src = 'https://elfsightcdn.com/platform.js';
        script.async = true;
        script.defer = true;
        document.body.appendChild(script);
        
        // Dejamos de observar una vez cargado
        observer.disconnect();
      }
    });
  }, {
    rootMargin: '200px' // Se activa 200px antes de que el usuario llegue al footer
  });

  // Apuntamos al contenedor de las reseñas
  const target = document.getElementById('google-reviews-widget');
  if (target) {
    observer.observe(target);
  }
</script>