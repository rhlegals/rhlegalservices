---
import { getEntry } from 'astro:content';

export interface Props {
  lang: 'es' | 'en';
  currentPath: string;
  variant?: 'dark' | 'light' | 'thankyou';
}

const { lang, currentPath, variant = 'dark' } = Astro.props;
const isEs = lang === 'es';
const isLight = variant === 'light';
const isThankyou = variant === 'thankyou';

const globalEntry = await getEntry('configuracion', 'global');
const globalConfig = globalEntry!.data;

const links = isEs ? globalConfig.navigation.es : globalConfig.navigation.en;

// Explicit bidirectional route map — avoids slug-mismatch 404s
const esToEn: Record<string, string> = {
  '/': '/en/',
  '/nuestra-firma': '/en/our-firm',
  '/derecho-marcario': '/en/trademark-law',
  '/derecho-migratorio': '/en/immigration-law',
  '/otros-servicios': '/en/other-services',
  '/blog': '/en/blog',
  '/politica-privacidad': '/en/privacy-policy',
  '/gracias': '/en/thank-you',
};
const enToEs: Record<string, string> = Object.fromEntries(
  Object.entries(esToEn).map(([es, en]) => [en, es])
);
// Normalise trailing slash for lookup
const normPath = currentPath.endsWith('/') && currentPath !== '/' && currentPath !== '/en/'
  ? currentPath.slice(0, -1)
  : currentPath;

const altLangHref = isEs
  ? (esToEn[normPath] ?? '/en/')
  : (enToEs[normPath] ?? '/');

const ctaHref = isEs ? '#contacto' : '#contact';
const ctaLabel = isEs ? 'Más Información' : 'More Information';

function linkClass(href: string) {
  const isActive = currentPath === href || (href !== '/' && href !== '/en/' && currentPath.startsWith(href));
  if (isThankyou) {
    return isActive
      ? 'px-3 xl:px-4 py-2 text-sm font-medium transition-colors whitespace-nowrap text-brand-500'
      : 'px-3 xl:px-4 py-2 text-sm font-medium transition-colors whitespace-nowrap text-gray-800 hover:text-brand-500';
  }
  if (isLight) {
    return isActive
      ? 'px-3 xl:px-4 py-2 text-sm font-medium rounded-md transition-colors whitespace-nowrap text-brand-500 bg-brand-50'
      : 'px-3 xl:px-4 py-2 text-sm font-medium rounded-md transition-colors whitespace-nowrap text-navy-800 hover:text-brand-500 hover:bg-brand-50';
  }
  return isActive
    ? 'px-3 xl:px-4 py-2 text-sm font-medium rounded-md transition-colors whitespace-nowrap text-brand-500 bg-white/10'
    : 'px-3 xl:px-4 py-2 text-sm font-medium rounded-md transition-colors whitespace-nowrap text-white/90 hover:text-brand-500 hover:bg-white/10';
}

---

<header
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${isLight || isThankyou ? globalConfig.theme.headerBgLight : ''}`}
  id="navbar"
  data-variant={variant}
  data-dark-classes={globalConfig.theme.headerBgDarkActive}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={isEs ? '/' : '/en/'} class="flex items-center group flex-shrink-0">
        <img
          src={globalConfig.siteLogo.image}
          alt={globalConfig.siteLogo.alt}
          class="h-10 lg:h-12 w-auto object-contain flex-shrink-0"
          loading="eager"
          width="160"
          height="48"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5 xl:gap-1">
        {links.map(link => (
          <a href={link.href} class={linkClass(link.href)}>
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-2 lg:gap-3">
        <!-- Language switcher — Base64 flags -->
       <div class="flex items-center gap-2 flex-shrink-0 z-50" style="min-width: 56px;">
          <a href={isEs ? currentPath : altLangHref} class="flex-shrink-0 block opacity-100" aria-label="Versión en Español" title="Español">
            <img 
              src="/images/co.png" 
              alt="Colombia" 
              width="24" 
              height="16" 
              style="width:24px; height:16px; display:block; object-fit:cover; border-radius: 2px;"
              loading="eager" 
              decoding="async" 
            />
          </a>
          <a href={isEs ? altLangHref : currentPath} class="flex-shrink-0 block opacity-40 hover:opacity-100" aria-label="Switch to English" title="English">
            <img 
              src="/images/us.png" 
              alt="USA" 
              width="24" 
              height="16" 
              style="width:24px; height:16px; display:block; object-fit:cover; border-radius: 2px;"
              loading="eager" 
              decoding="async" 
            />
          </a>
        </div>

        <!-- CTA Button -->
        <a
          href={ctaHref}
          class="hidden sm:inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white text-sm font-bold px-4 xl:px-5 py-2.5 rounded-lg transition-all duration-200 shadow-lg hover:shadow-brand-500/30 whitespace-nowrap"
        >
          {ctaLabel}
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class={`lg:hidden p-2 rounded-md transition-colors ${
            isThankyou
              ? 'text-gray-700 hover:text-brand-500'
              : isLight
                ? 'text-navy-700 hover:text-brand-500 hover:bg-brand-50'
                : 'text-white/80 hover:text-white hover:bg-white/10'
          }`}
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-navy-900/95 backdrop-blur-md border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-1">
      {links.map(link => (
        <a
          href={link.href}
          class="block px-4 py-3 text-sm font-medium text-white/90 hover:text-brand-500 hover:bg-white/5 rounded-md transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3 pb-1 border-t border-white/10 flex justify-end">
        <a href={ctaHref} class="inline-flex items-center bg-brand-500 hover:bg-brand-600 text-white text-sm font-bold px-4 py-2 rounded-lg transition-colors">
          {ctaLabel}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');
  const v = navbar?.dataset.variant;
  const isStatic = v === 'light' || v === 'thankyou';
  const darkClasses = (navbar?.dataset.darkClasses ?? '').split(' ').filter(Boolean);

  function updateNavbar() {
    if (isStatic) return;
    if (window.scrollY > 50) {
      navbar?.classList.add(...darkClasses);
      navbar?.classList.remove('bg-transparent');
    } else {
      navbar?.classList.remove(...darkClasses);
      navbar?.classList.add('bg-transparent');
    }
  }
  updateNavbar();
  window.addEventListener('scroll', updateNavbar);

  mobileMenuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuIconOpen?.classList.toggle('hidden', !isOpen);
    menuIconClose?.classList.toggle('hidden', isOpen);
    mobileMenuBtn?.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
