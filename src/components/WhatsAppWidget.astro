---
import { getEntry } from 'astro:content';

export interface Props {
  lang: 'es' | 'en';
  page?: string;
}

const { lang, page = 'home' } = Astro.props;
const isEs = lang === 'es';

const globalEntry = await getEntry('configuracion', 'global');
const globalConfig = globalEntry?.data;

const fallbackMessages = {
  home:       { es: 'Hola, me interesa conocer más sobre sus servicios legales en Colombia.', en: 'Hello, I am interested in learning more about your legal services in Colombia.' },
  immigration:{ es: 'Hola, necesito información sobre visas y trámites migratorios en Colombia.', en: 'Hello, I need information about visas and immigration procedures in Colombia.' },
  trademark:  { es: 'Hola, quiero registrar una marca en Colombia y necesito asesoría.', en: 'Hello, I want to register a trademark in Colombia and need advice.' },
  other:      { es: 'Hola, quisiera información sobre sus servicios legales.', en: 'Hello, I would like information about your legal services.' },
};

const whatsappData = globalConfig?.whatsapp || { phone: '573002170870', prefilledMessages: fallbackMessages };
const phone = whatsappData.phone || '573002170870';

const pageMessages = whatsappData.prefilledMessages as Record<string, { es: string; en: string }>;
const msgSet = pageMessages[page] ?? pageMessages['home'] ?? fallbackMessages.home;
const message = encodeURIComponent(isEs ? msgSet.es : msgSet.en);

const greeting = isEs
  ? '¿Necesitas asesoría legal en Colombia? Escríbenos, estamos listos para ayudarte.'
  : 'Do you need legal advice in Colombia? Write to us, we are ready to help you.';

const waUrl = `https://wa.me/${phone}?text=${message}`;
const btnLabel = isEs ? 'Chatear por WhatsApp' : 'Chat on WhatsApp';
const helpText = isEs ? '¿Necesitas ayuda?' : 'Need help?';
---

<div id="wa-widget" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">

  <!-- Chat bubble — hidden by default, toggled by button click -->
  <div
    id="wa-bubble"
    class="hidden max-w-[17rem] sm:max-w-xs bg-white rounded-2xl shadow-2xl p-4 border border-gray-100 opacity-0 translate-y-2 transition-all duration-300"
    role="dialog"
    aria-label={isEs ? 'Chat de WhatsApp' : 'WhatsApp Chat'}
  >
    <div class="flex items-start gap-3">
      <div class="w-10 h-10 rounded-full bg-[#25D366] flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs font-bold text-navy-900 mb-0.5">RH Legal Services</p>
        <p class="text-xs text-gray-600 leading-relaxed">{greeting}</p>
      </div>
      <button id="wa-close" class="ml-1 text-gray-400 hover:text-gray-600 flex-shrink-0 p-0.5" aria-label="Cerrar">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <a
      href={waUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 w-full flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#20bb5a] text-white text-xs font-bold py-2.5 px-4 rounded-xl transition-colors"
    >
      {btnLabel}
    </a>
  </div>

  <!-- Floating button + label -->
  <div class="flex items-center gap-2">
    <!-- Help label — visible on md+ -->
    <span class="hidden sm:block bg-white text-navy-800 text-xs font-semibold px-3 py-1.5 rounded-full shadow-md border border-gray-100 whitespace-nowrap">
      {helpText}
    </span>

    <!-- Toggle button -->
    <button
      id="wa-btn"
      type="button"
      class="relative w-14 h-14 bg-[#25D366] hover:bg-[#20bb5a] rounded-full flex items-center justify-center shadow-xl hover:shadow-green-400/40 hover:scale-110 transition-all duration-200"
      aria-label={btnLabel}
      aria-expanded="false"
      aria-controls="wa-bubble"
    >
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
      <span class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full flex items-center justify-center text-white text-xs font-bold shadow">1</span>
    </button>
  </div>
</div>

<script>
  window.addEventListener('load', () => {
    const bubble = document.getElementById('wa-bubble');
    const btn = document.getElementById('wa-btn');
    const closeBtn = document.getElementById('wa-close');

    function openBubble() {
      if (!bubble) return;
      bubble.classList.remove('hidden');
      requestAnimationFrame(() => {
        bubble.classList.remove('opacity-0', 'translate-y-2');
      });
      btn?.setAttribute('aria-expanded', 'true');
    }

    function closeBubble() {
      if (!bubble) return;
      bubble.classList.add('opacity-0', 'translate-y-2');
      setTimeout(() => bubble.classList.add('hidden'), 300);
      btn?.setAttribute('aria-expanded', 'false');
    }

    btn?.addEventListener('click', () => {
      const isOpen = !bubble?.classList.contains('hidden');
      isOpen ? closeBubble() : openBubble();
    });

    closeBtn?.addEventListener('click', closeBubble);
  });
</script>
